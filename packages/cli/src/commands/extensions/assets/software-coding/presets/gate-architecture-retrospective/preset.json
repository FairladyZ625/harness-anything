{
  "schema": "preset-manifest/v2",
  "id": "gate-architecture-retrospective",
  "title": "Gate Architecture Retrospective",
  "vertical": "software/coding",
  "version": "1.0.0",
  "kind": "process-action",
  "kernelVersionRange": { "min": "1.0.0", "maxExclusive": "2.0.0" },
  "capabilityImports": [
    { "id": "gate-retro-gather", "kind": "command", "version": "1", "required": true },
    { "id": "gate-retro-checker", "kind": "checker", "version": "1", "required": true }
  ],
  "entrypoints": {
    "gather": {
      "type": "script",
      "command": "scripts/gate-retro-data.mjs",
      "reads": [
        "{{paths.rootDir}}/package.json",
        "{{paths.rootDir}}/eslint.config.mjs",
        "{{paths.rootDir}}/.github/**",
        "{{paths.rootDir}}/tools/**",
        "{{paths.rootDir}}/packages/**",
        "{{paths.tasksRoot}}/*/artifacts/gate-retro.snapshot.json"
      ],
      "writes": [
        "{{outputRoot}}/artifacts/**"
      ],
      "inputs": {
        "coordinationTaskId": "{{taskId}}",
        "previousSnapshot": ""
      }
    }
  },
  "profiles": [{
    "id": "baseline",
    "title": "Baseline",
    "checkerProfile": "software-coding-standard",
    "templateSelections": [
      {
        "slot": "gate-retro-analysis",
        "templateRef": "template://gate-retro/analysis@1",
        "materializeAs": "artifacts/gate-retro.analysis.scaffold.md",
        "localePolicy": { "prefer": "project", "fallback": "zh-CN" }
      }
    ]
  }],
  "defaultProfile": "baseline"
}
