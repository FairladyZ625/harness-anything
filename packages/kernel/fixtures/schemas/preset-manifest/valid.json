{
  "schema": "preset-manifest/v1",
  "id": "software-coding-standard",
  "title": "Software Coding Standard",
  "vertical": "software/coding",
  "version": "1.0.0",
  "kernelVersionRange": {
    "min": "1.0.0",
    "maxExclusive": "2.0.0"
  },
  "capabilityImports": [
    {
      "id": "schema-contracts",
      "kind": "checker",
      "version": "1",
      "required": true
    },
    {
      "id": "task-flow-template",
      "kind": "template",
      "version": "1",
      "required": true
    }
  ],
  "profiles": [
    {
      "id": "baseline",
      "title": "Baseline",
      "checkerProfile": "standard",
      "templateSelections": [
        {
          "slot": "task.flow",
          "templateRef": "template://planning/task-flow@1",
          "materializeAs": "task_flow.md",
          "localePolicy": {
            "prefer": "project",
            "fallback": "en-US"
          }
        }
      ]
    }
  ],
  "defaultProfile": "baseline"
}
